APP_NAME=Auto Group
APP_HOST=127.0.0.1
APP_PORT=8080
DATABASE_URL=sqlite:///./data/auto_group.db
JWT_SECRET=change-this-secret
JWT_EXPIRE_MINUTES=10080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
# 自定义后台入口；公网部署时建议改成不容易猜到的路径，例如 /manage-a8f3c2
ADMIN_ROUTE_PREFIX=/admin
# 前端上 CDN 时保持 false；只有希望后端直接托管 frontend/dist 时才改 true
FRONTEND_STATIC_ENABLED=false
# CDN 域名固定后建议配置精确来源，例如 https://cdn.example.com；多个用逗号分隔
CORS_ORIGINS=*
PUBLIC_FALLBACK_MESSAGE=当前没有可加入的群，请稍后再试。
UPLOAD_DIR=./uploads
GROUP_SYNC_INTERVAL_SECONDS=60
GROUP_SYNC_CONCURRENCY=3
ONEBOT_API_TIMEOUT_SECONDS=15
GROUP_MEMBER_SYNC_TIMEOUT_SECONDS=300
MEMBER_SNAPSHOT_DAILY_TIME=03:00
# WebSocket 心跳：设为 0 可关闭服务端 ping；网络抖动时可调大 timeout
WS_PING_INTERVAL_SECONDS=20
WS_PING_TIMEOUT_SECONDS=60
LOGIN_RATE_LIMIT_MAX_FAILURES=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_LOCK_SECONDS=900
# 只有在源站已由可信反代/CDN保护且会清洗伪造头时才设为 true
LOGIN_RATE_LIMIT_TRUST_PROXY_HEADERS=false
